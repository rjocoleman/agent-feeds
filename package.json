{
	"name": "@rjocoleman/agent-feeds",
	"version": "0.1.0",
	"description": "Pure TypeScript library for reading RSS/Atom/JSON Feed. Markdown output optimised for LLM context windows.",
	"license": "MIT",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"src",
		"dist",
		"!src/**/*.test.ts",
		"!src/fixtures",
		"!src/testing"
	],
	"bin": {
		"agent-feeds": "src/cli.ts"
	},
	"engines": {
		"bun": ">=1.0"
	},
	"scripts": {
		"build": "rm -rf dist && bunx tsc -p tsconfig.build.json",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit",
		"check": "biome check . && bunx tsc --noEmit && bun test",
		"prepublishOnly": "bun run check && bun run build",
		"cli": "bun run src/cli.ts",
		"version": "bun run scripts/version.ts"
	},
	"dependencies": {
		"@extractus/article-extractor": "^8.0.20",
		"rss-parser": "^3.13.0",
		"turndown": "^7.2.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"@types/turndown": "^5.0.6"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
